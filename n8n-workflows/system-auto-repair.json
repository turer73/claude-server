        [{ "node": "Has Fix Commands?", "type": "main", "index": 0 }]
      ]
    },
    "Has Fix Commands?": {
      "main": [
        [{ "node": "Split Commands", "type": "main", "index": 0 }],
        [{ "node": "Wait for Fix Effect", "type": "main", "index": 0 }]
      ]
    },
    "Split Commands": {
      "main": [
        [{ "node": "Loop Commands", "type": "main", "index": 0 }]
      ]
    },
    "Loop Commands": {
      "main": [
        [{ "node": "Wait for Fix Effect", "type": "main", "index": 0 }],
        [{ "node": "Execute Fix", "type": "main", "index": 0 }]
      ]
    },
    "Execute Fix": {
      "main": [
        [{ "node": "Wait Between Commands", "type": "main", "index": 0 }]
      ]
    },
    "Wait Between Commands": {
      "main": [
        [{ "node": "Loop Commands", "type": "main", "index": 0 }]
      ]
    },
    "Wait for Fix Effect": {
