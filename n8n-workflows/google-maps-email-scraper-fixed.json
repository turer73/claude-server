      "id": "e6957d05-3533-48ae-9cc1-ee4ac026a2a6",
      "name": "Loop over pages",
      "type": "n8n-nodes-base.splitInBatches",
      "position": [2288, 720],
      "typeVersion": 3,
      "alwaysOutputData": false,
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// FIX #2: null-safe + undefined-safe + improved email regex\n// Orijinal: data.match() null donebilir → downstream crash\n// Orijinal: data undefined olabilir → TypeError\n// Orijinal regex: .webp, .svg, .css, .js gibi uzantilar filtrelenmiyordu\n\nconst data = $json.data || ''\n\nif (!data || data.length < 10) {\n  return {json: {emails: []}}\n}\n\n// Iyilestirilmis email regex:\n// - Resim uzantilari: png, jpg, gif, jpeg, webp, svg, ico\n// - Kod/font uzantilari: css, js, woff, woff2, map, ttf, eot\n// - Diger: pdf (genelde dosya adi, email degil)\nconst emailRegex = /[a-zA-Z0-9._%+-]+@[a-zA-Z0-9.-]+\\.(?!png|jpg|gif|jpeg|webp|svg|ico|css|js|woff2?|map|ttf|eot|pdf\\b)[a-zA-Z]{2,}/g\n\nconst emails = data.match(emailRegex) || []\n\n// Acikca gecersiz olan emailleri temizle\nconst cleaned = emails.filter(email => {\n  // Cok kisa domain (a@b.cc minimum)\n  if (email.length < 6) return false\n  // Sayi ile baslayan domain (genelde IP veya hash)\n  const domain = email.split('@')[1]\n  if (/^\\d/.test(domain)) return false\n  // Placeholder/test emailleri\n  if (/example\\.com|test\\.com|email\\.com|domain\\.com|placeholder/i.test(email)) return false\n  return true\n})\n\nreturn {json: {emails: cleaned}}"
      },
