      "id": "3a478935-781b-4fb1-bdc7-fcf8be1334bc",
      "name": "Search Google Maps with query",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1280, 992],
      "executeOnce": false,
      "typeVersion": 4.2,
      "alwaysOutputData": false
    },
    {
      "parameters": {
        "jsCode": "// FIX #1: null-safe + improved regex\n// Orijinal: data.match(regex) null donebilir → crash\n// Orijinal regex: sadece domain yakaliyordu, cok gurultulu\n\nconst data = $input.first().json.data || ''\n\n// URL'leri yakala (scheme + domain + optional path)\nconst regex = /https?:\\/\\/[^\\s\"'<>\\)\\]]+/g\nconst rawUrls = data.match(regex) || []\n\n// Sadece domain'e indir (path'ler Google Maps icinde yaniltici olabilir)\nconst domains = rawUrls.map(url => {\n  try {\n    const u = new URL(url)\n    return u.origin\n  } catch(e) {\n    return url.match(/https?:\\/\\/[^\\/]+/)?.[0] || null\n  }\n}).filter(Boolean)\n\n// Tekrarlari kaldir\nconst uniqueDomains = [...new Set(domains)]\n\n// Bilinen gereksiz domain'leri hemen filtrele (downstream yukunu azalt)\nconst excludePattern = /google\\.|gstatic\\.|googleapis\\.|ggpht\\.|schema\\.org|example\\.com|w3\\.org|mozilla\\.org|apache\\.org|cloudflare|cdn\\.|fonts\\./i\n\nconst filtered = uniqueDomains.filter(url => !excludePattern.test(url))\n\nif (filtered.length === 0) {\n  return [{json: {url: '', _empty: true, _info: 'Google Maps sonuclarindan hicbir isletme URL\\'si bulunamadi'}}]\n}\n\nreturn filtered.map(url => ({json: {url: url}}))"
      },
