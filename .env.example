# .env.example — Copy to .env and fill in values

# Linux-AI Server
JWT_SECRET=your-secure-jwt-secret-here
DEFAULT_API_KEY=your-admin-api-key-here

# n8n
N8N_USER=admin
N8N_PASSWORD=your-n8n-password

# Web Services (optional)
VERCEL_TOKEN=
CLOUDFLARE_TOKEN=
GITHUB_TOKEN=
SUPABASE_URL=
SUPABASE_TOKEN=
COOLIFY_URL=
COOLIFY_TOKEN=
