# .env.example — Copy to .env and fill in values

# ── Auth ──
JWT_SECRET=your-secure-jwt-secret-here
API_KEY=your-admin-api-key-here
INTERNAL_API_KEY=your-internal-admin-api-key-here
MEMORY_API_KEY=your-memory-api-key-here

# ── SSH / MCP ──
MCP_SSH_USER=your-ssh-username
MCP_SSH_HOST=your-server-ip
MCP_SSH_PASS=your-ssh-password

# ── VPS ──
VPS_HOST=user@your-vps-ip

# ── E2E Test Credentials ──
E2E_EMAIL=
E2E_PASSWORD=
PETVET_PHONE=
PETVET_PASS=
PETVET_PIN=
KUAFOR_PHONE=
KUAFOR_PASS=
E2E_SUPABASE_URL=

# ── Web Services (optional) ──
VERCEL_TOKEN=
CLOUDFLARE_TOKEN=
GITHUB_TOKEN=
SUPABASE_URL=
SUPABASE_TOKEN=
COOLIFY_URL=
COOLIFY_TOKEN=

# ── n8n ──
N8N_USER=admin
N8N_PASSWORD=

# ── Telegram Bildirim ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── DevOps Agent Watchlists (CSV; defaults in app/core/config.py reflect host state) ──
# MONITOR_CRITICAL_SERVICES=linux-ai-server,ollama
# MONITOR_CRITICAL_CONTAINERS=dozzle,uptime-kuma
# MONITOR_VPS_CONTAINERS=panola-postgres,panola-caddy,panola-postgrest,panola-auth,n8n,grafana,prometheus,dokploy-traefik,plausible-plausible-1

# ── Alert/auto-bug yaşam-döngüsü (notify-cron) ──
# NOTIFY_CRON_ENABLED: events->Telegram bildirimi (ana anahtar)
# NOTIFY_CRON_ENABLED=true
# RESOLVE_QUIET_MIN: kaynak bu kadar dk sessizse AUTO-alert bug auto-resolve (Slice A)
# RESOLVE_QUIET_MIN=90
# RECUR_DAYS / RECUR_THRESHOLD: tekrar-deseni penceresi/eşiği (Slice C; >=N -> 🔁)
# RECUR_DAYS=7
# RECUR_THRESHOLD=3
# AUTO_INVESTIGATE_ENABLED: tekrarlayan-critical -> otonom salt-okunur /claude kök-neden
#   incelemesi (Slice B). Default KAPALI; Max-plan otonom-çağrı, rate-limit 1/saat/kaynak.
# AUTO_INVESTIGATE_ENABLED=false
